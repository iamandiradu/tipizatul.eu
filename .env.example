# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and must never be committed.

# ── Firebase ──────────────────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── Google Drive (server-side proxy) ─────────────────────────────────────────
# Service account JSON key for the /api/pdf proxy that fetches Drive PDFs.
# Paste the raw JSON or a base64-encoded version of the key file.
# See DEPLOYMENT.md §2 for setup instructions.
#BASE64
GOOGLE_SERVICE_ACCOUNT_KEY=
