# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and must never be committed.

# ── Firebase ──────────────────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── Google Drive API ──────────────────────────────────────────────────────────
# Server-side key used by the /api/pdf Vercel proxy (production).
# Do NOT prefix with VITE_ — must stay server-side only.
# In Google Cloud Console: restrict to "Google Drive API" only (no HTTP referrer restriction needed).
GOOGLE_DRIVE_API_KEY=

# Dev-only browser key (used when running `npm run dev` locally).
# Restrict to HTTP referrers: localhost:5173.
# Not needed in production — the serverless proxy uses GOOGLE_DRIVE_API_KEY instead.
VITE_GOOGLE_DRIVE_API_KEY=
